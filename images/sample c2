    <div class="cinema-card rev" data-cat="撮影機材" data-delay="80">
      <div class="c-img"><div class="c-img-inner"><img src="images/dji-osmo-pocket-4.jpg" alt="DJI Osmo Pocket 4"></div></div>
      <div class="c-body">
        <div class="c-meta"><span class="c-tag">撮影機材</span><span class="c-date">2026年6月27日</span></div>
