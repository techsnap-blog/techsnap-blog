<!DOCTYPE html>
<html lang="ja">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>TechSnap — ガジェット・カメラ・撮影機材レビュー</title>
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link href="https://fonts.googleapis.com/css2?family=Shippori+Mincho:wght@400;600;700&family=Inter:wght@400;500;600;700;800&family=Noto+Sans+JP:wght@400;500;700&display=swap" rel="stylesheet">
  <style>
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
    :root {
      --bg:        #f7f4ee;
      --paper:     #f0ece3;
      --white:     #ffffff;
      --ink:       #19150f;
      --ink-mid:   #3d3730;
      --ink-soft:  #7a6e62;
      --border:    #ddd6c8;
      --accent:    #9c5c24;
      --accent-lt: #f6ede0;
      --accent-dk: #7a4418;
      --green:     #2d6e40;
      --gold1: rgba(212,168,67,0.85);
      --gold2: rgba(170,176,184,0.7);
      --gold3: rgba(196,122,69,0.75);
    }
    html { scroll-behavior: smooth; }
    body {
      font-family: 'Inter','Noto Sans JP',sans-serif;
      background: var(--bg); color: var(--ink);
      overflow-x: hidden; -webkit-font-smoothing: antialiased;
    }
    a { text-decoration: none; color: inherit; }

    /* ─── HEADER ─── */
    .site-header {
      position: fixed; top: 0; left: 0; right: 0; z-index: 300;
      height: 56px; padding: 0 48px;
      display: flex; align-items: center; justify-content: space-between;
      background: rgba(247,244,238,0.97); backdrop-filter: blur(16px);
      border-bottom: 1px solid var(--border);
      transition: box-shadow 0.3s;
    }
    .site-header.shadow { box-shadow: 0 2px 24px rgba(25,21,15,0.07); }
    .logo {
      font-family: 'Shippori Mincho', serif;
      font-size: 1.2rem; font-weight: 700; letter-spacing: 0.06em; color: var(--ink);
    }
    .logo em { font-style: normal; color: var(--accent); }
    .nav { display: flex; gap: 28px; }
    .nav a {
      font-size: 0.72rem; font-weight: 700; color: var(--ink-soft);
      letter-spacing: 0.12em; text-transform: uppercase;
      transition: color 0.2s;
    }
    .nav a:hover { color: var(--ink); }

    /* ─── HERO ─── */
    .hero {
      margin-top: 56px; min-height: calc(100vh - 56px);
      display: grid; grid-template-columns: 1fr 1fr;
      background: var(--ink); overflow: hidden;
      position: relative;
    }
    /* 左：テキスト */
    .hero-text {
      padding: 80px 56px 80px 72px;
      display: flex; flex-direction: column; justify-content: center;
      position: relative; z-index: 2;
    }
    .hero-kicker {
      font-size: 0.65rem; font-weight: 700; letter-spacing: 0.22em;
      text-transform: uppercase; color: var(--accent);
      margin-bottom: 20px; opacity: 0;
      animation: fadeUp 0.6s 0.2s forwards;
    }
    .hero-h1 {
      font-family: 'Shippori Mincho', serif;
      font-size: clamp(1.9rem, 3.2vw, 3rem);
      font-weight: 700; line-height: 1.25; color: var(--white);
      letter-spacing: -0.01em; margin-bottom: 20px;
      opacity: 0; animation: fadeUp 0.8s 0.45s forwards;
    }
    .hero-desc {
      font-size: 0.875rem; color: rgba(255,255,255,0.52);
      line-height: 1.85; max-width: 380px; margin-bottom: 36px;
      opacity: 0; animation: fadeUp 0.8s 0.7s forwards;
    }
    .hero-scores {
      display: flex; gap: 0;
      border: 1px solid rgba(255,255,255,0.12); border-radius: 6px;
      overflow: hidden; width: fit-content;
      opacity: 0; animation: fadeUp 0.8s 0.95s forwards;
    }
    .hs-item {
      padding: 12px 18px; text-align: center;
      border-right: 1px solid rgba(255,255,255,0.1);
    }
    .hs-item:last-child { border-right: none; }
    .hs-label { font-size: 0.55rem; color: rgba(255,255,255,0.35); letter-spacing: 0.1em; text-transform: uppercase; display: block; margin-bottom: 3px; }
    .hs-val { font-size: 1.05rem; font-weight: 800; color: #90d490; display: block; }
    .hs-item.total { background: rgba(255,255,255,0.05); }
    .hs-item.total .hs-val { color: #a0e0a0; font-size: 1.2rem; }
    /* 右：画像 */
    .hero-visual {
      position: relative; overflow: hidden;
      background: linear-gradient(135deg, #2a1e14 0%, #3e2c1c 100%);
    }
    .hero-visual::before {
      content: ''; position: absolute; inset: 0;
      background: radial-gradient(ellipse at 40% 50%, rgba(156,92,36,0.2) 0%, transparent 65%);
    }
    .hero-visual-img {
      position: absolute; inset: 0;
      display: flex; align-items: center; justify-content: center;
      padding: 48px;
      opacity: 0; animation: fadeIn 1.2s 0.6s forwards;
    }
    .hero-visual-img img {
      max-width: 100%; max-height: 100%; object-fit: contain;
      filter: drop-shadow(0 20px 48px rgba(0,0,0,0.5));
      transform: scale(0.95); animation: floatIn 1.2s 0.6s cubic-bezier(0.22,1,0.36,1) forwards;
    }
    @keyframes floatIn {
      from { opacity: 0; transform: scale(0.88) translateY(16px); }
      to { opacity: 1; transform: scale(1) translateY(0); }
    }
    /* 左下のスクロールヒント */
    .scroll-hint {
      position: absolute; bottom: 32px; left: 72px;
      display: flex; align-items: center; gap: 10px;
      color: rgba(255,255,255,0.25); font-size: 0.6rem; letter-spacing: 0.16em; text-transform: uppercase;
      opacity: 0; animation: fadeUp 0.6s 1.4s forwards;
    }
    .scroll-dot {
      width: 6px; height: 6px; border-radius: 50%; background: var(--accent);
      animation: pulse 2s ease-in-out infinite;
    }
    @keyframes pulse { 0%,100%{opacity:0.4;transform:scale(1)} 50%{opacity:1;transform:scale(1.3)} }
    @keyframes fadeUp {
      from { opacity: 0; transform: translateY(14px); }
      to { opacity: 1; transform: translateY(0); }
    }
    @keyframes fadeIn {
      from { opacity: 0; } to { opacity: 1; }
    }

    /* ─── FILTER BAR ─── */
    .filter-bar {
      background: var(--white); border-bottom: 1px solid var(--border);
      padding: 0 48px;
      display: flex; align-items: center; gap: 4px;
      overflow-x: auto; scrollbar-width: none; height: 50px;
    }
    .filter-bar::-webkit-scrollbar { display: none; }
    .f-btn {
      flex-shrink: 0; background: none; border: none;
      font-family: inherit; font-size: 0.73rem; font-weight: 600;
      color: var(--ink-soft); letter-spacing: 0.04em;
      padding: 6px 14px; border-radius: 999px; cursor: pointer;
      transition: all 0.18s; white-space: nowrap;
    }
    .f-btn:hover { background: var(--paper); color: var(--ink); }
    .f-btn.active { background: var(--accent); color: var(--white); }

    /* ─── CINEMA CARDS ─── */
    .cinema-wrap { padding: 72px 48px 80px; max-width: 1200px; margin: 0 auto; }
    .section-eyebrow {
      font-size: 0.63rem; font-weight: 700; color: var(--ink-soft);
      letter-spacing: 0.2em; text-transform: uppercase;
      margin-bottom: 48px;
      display: flex; align-items: center; gap: 18px;
    }
    .section-eyebrow::after { content:''; flex:1; height:1px; background:var(--border); }

    .cinema-card {
      display: grid; grid-template-columns: 5fr 7fr;
      border: 1px solid var(--border); border-radius: 10px;
      overflow: hidden; background: var(--white);
      margin-bottom: 28px;
      opacity: 0; transform: translateY(28px);
      transition: opacity 0.65s, transform 0.65s cubic-bezier(0.22,1,0.36,1), box-shadow 0.25s;
    }
    .cinema-card.visible { opacity: 1; transform: translateY(0); }
    .cinema-card:hover { box-shadow: 0 16px 56px rgba(25,21,15,0.1); }
    .cinema-card.rev { grid-template-columns: 7fr 5fr; }
    .cinema-card.rev .c-img { order: 2; }
    .cinema-card.rev .c-body { order: 1; }

    .c-img {
      position: relative; overflow: hidden; min-height: 300px;
      background: var(--paper);
    }
    .c-img-inner {
      position: absolute; inset: 0;
      display: flex; align-items: center; justify-content: center;
      padding: 28px; transition: transform 0.6s cubic-bezier(0.22,1,0.36,1);
    }
    .cinema-card:hover .c-img-inner { transform: scale(1.05); }
    .c-img img { max-width: 100%; max-height: 100%; object-fit: contain; }

    .c-body {
      padding: 44px 48px; display: flex; flex-direction: column; justify-content: center;
    }
    .c-meta { display: flex; align-items: center; gap: 10px; margin-bottom: 16px; }
    .c-tag {
      background: var(--accent-lt); color: var(--accent);
      font-size: 0.63rem; font-weight: 700; letter-spacing: 0.08em;
      padding: 3px 10px; border-radius: 3px;
    }
    .c-date { font-size: 0.68rem; color: var(--ink-soft); }
    .c-title {
      font-family: 'Shippori Mincho', serif;
      font-size: clamp(1.05rem, 1.8vw, 1.4rem);
      font-weight: 700; line-height: 1.45; letter-spacing: -0.01em;
      margin-bottom: 14px; color: var(--ink);
    }
    .c-title a:hover { color: var(--accent); }
    .c-excerpt {
      font-size: 0.82rem; color: var(--ink-soft); line-height: 1.85;
      margin-bottom: 22px;
    }
    .c-score-row { display: flex; align-items: center; gap: 12px; }
    .c-score-main {
      font-size: 0.72rem; font-weight: 700; color: var(--green);
      display: flex; align-items: baseline; gap: 3px;
    }
    .c-score-main strong { font-size: 1.3rem; font-weight: 800; }
    .c-score-bar {
      flex: 1; height: 3px; background: var(--border); border-radius: 2px; overflow: hidden; max-width: 120px;
    }
    .c-score-bar-fill {
      height: 100%; background: linear-gradient(90deg, var(--green), #6abf80);
      border-radius: 2px; transform: scaleX(0); transform-origin: left;
      transition: transform 0.8s 0.3s cubic-bezier(0.22,1,0.36,1);
    }
    .cinema-card.visible .c-score-bar-fill { transform: scaleX(1); }

    /* ─── RANKING ─── */
    .ranking-wrap {
      background: var(--ink); padding: 72px 48px 80px;
    }
    .rank-eyebrow {
      font-size: 0.63rem; font-weight: 700; letter-spacing: 0.2em;
      text-transform: uppercase; color: rgba(255,255,255,0.3);
      margin-bottom: 48px;
      display: flex; align-items: center; gap: 18px;
    }
    .rank-eyebrow::after { content:''; flex:1; height:1px; background:rgba(255,255,255,0.08); }

    .rank-grid {
      display: grid; grid-template-columns: 1fr 1fr; gap: 16px;
      max-width: 900px;
    }
    .rank-card {
      display: flex; align-items: center; gap: 20px;
      padding: 20px 24px; border-radius: 8px;
      border: 1px solid rgba(255,255,255,0.07);
      background: rgba(255,255,255,0.03);
      opacity: 0; transform: translateY(16px);
      transition: opacity 0.5s, transform 0.5s, background 0.2s;
    }
    .rank-card.visible { opacity: 1; transform: translateY(0); }
    .rank-card:hover { background: rgba(255,255,255,0.06); }
    .r-num {
      font-family: 'Shippori Mincho', serif;
      font-size: 2rem; font-weight: 700;
      color: rgba(255,255,255,0.1); width: 36px; flex-shrink: 0; text-align: center; line-height: 1;
    }
    .rank-card:nth-child(1) .r-num { color: var(--gold1); }
    .rank-card:nth-child(2) .r-num { color: var(--gold2); }
    .rank-card:nth-child(3) .r-num { color: var(--gold3); }
    .r-body { flex: 1; }
    .r-tag { font-size: 0.6rem; font-weight: 700; color: var(--accent); letter-spacing: 0.08em; text-transform: uppercase; display: block; margin-bottom: 4px; }
    .r-title { font-size: 0.82rem; color: rgba(255,255,255,0.75); line-height: 1.5; }
    .r-score { font-size: 0.78rem; font-weight: 800; color: #90d490; flex-shrink: 0; }

    .rank-card.span2 { grid-column: span 2; }

    /* ─── FOOTER ─── */
    .site-footer {
      background: var(--ink); border-top: 1px solid rgba(255,255,255,0.05);
      padding: 32px 48px;
      display: flex; align-items: center; justify-content: space-between;
    }
    .footer-logo { font-family: 'Shippori Mincho', serif; font-size: 1.05rem; color: rgba(255,255,255,0.4); }
    .footer-logo em { font-style: normal; color: var(--accent); }
    .footer-links { display: flex; gap: 20px; }
    .footer-links a { font-size: 0.7rem; color: rgba(255,255,255,0.25); }
    .footer-links a:hover { color: rgba(255,255,255,0.5); }
    .footer-copy { font-size: 0.68rem; color: rgba(255,255,255,0.18); }

    /* ─── RESPONSIVE ─── */
    @media (max-width: 768px) {
      .site-header { padding: 0 20px; }
      .nav { display: none; }
      .hero { grid-template-columns: 1fr; min-height: auto; }
      .hero-text { padding: 48px 24px; }
      .hero-visual { height: 280px; }
      .scroll-hint { left: 24px; }
      .filter-bar { padding: 0 20px; }
      .cinema-wrap { padding: 48px 20px; }
      .cinema-card, .cinema-card.rev { grid-template-columns: 1fr; }
      .cinema-card.rev .c-img { order: 0; }
      .cinema-card.rev .c-body { order: 0; }
      .c-body { padding: 24px; }
      .ranking-wrap { padding: 48px 20px; }
      .rank-grid { grid-template-columns: 1fr; }
      .rank-card.span2 { grid-column: span 1; }
      .site-footer { padding: 24px 20px; flex-direction: column; gap: 12px; text-align: center; }
    }
  </style>
</head>
<body>

  <!-- HEADER -->
  <header class="site-header" id="siteHeader">
    <a href="#" class="logo">Tech<em>Snap</em></a>
    <nav class="nav">
